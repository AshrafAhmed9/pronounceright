# Azure AI Speech resource (Speech Services), Central India region recommended
# for DPDP data-residency. Create at portal.azure.com -> "Speech service" ->
# free F0 pricing tier.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralindia
AZURE_SPEECH_LANGUAGE=en-US

# Coaching-tip LLM: tried in this order, first configured key wins.
# Gemini: create a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq: create a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# Comma-separated list of allowed frontend origins for CORS.
FRONTEND_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
